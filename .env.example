# ── Elasticsearch (nur lesend) ───────────────────────────────────────────────
# Eigenständiger Stack: ES über den Host (ES publisht :9200; compose mappt host.docker.internal):
ES_URL=http://host.docker.internal:9200
# Im selben Docker-Netz wäre es stattdessen: http://elasticsearch:9200
ES_INDICES=rookhub-logs-*,crawler-logs-*
# Auth optional. Der rookhub-ES läuft mit xpack.security.enabled=false -> leer lassen.
# ES_API_KEY=
# ES_USER=
# ES_PASSWORD=
# Feldnamen ggf. an den Serilog-Sink anpassen (Defaults passen zu Serilog.Sinks.Elasticsearch):
ES_TIMESTAMP_FIELD=@timestamp
# Aggregation braucht ein keyword-Feld. Serilog mappt 'level' oft als text+keyword
# -> level.keyword. (Falls dein Mapping 'level' direkt als keyword hat: einfach 'level'.)
ES_LEVEL_FIELD=level.keyword
ES_MESSAGE_FIELD=messageTemplate.keyword
ES_ERROR_LEVELS=Error,Fatal
ES_WARN_LEVELS=Warning
# Alerts zur Kibana-Historie zurück nach ES schreiben (eigener Index, replicas=0):
ES_INDEX_ALERTS=true
ES_ALERT_INDEX_PREFIX=log-watcher-alerts

# ── Fenster / Intervall ───────────────────────────────────────────────────────
WINDOW_HOURS=6
INTERVAL_SECONDS=21600
# RUN_ONCE=true   # einmal laufen und beenden (Test/Cron)

# ── Cheap-Rules (Gate vor dem LLM) ────────────────────────────────────────────
MIN_ERRORS=5
ERROR_SPIKE_FACTOR=3.0
# Warnungen sind lauter -> höhere Mindestmenge, eigener Faktor, abschaltbar:
MIN_WARNINGS=20
WARN_SPIKE_FACTOR=3.0
ALERT_ON_WARN_SPIKE=true
ALERT_ON_NEW_SIGNATURES=true
INGESTION_DROP_CHECK=true

# ── LLM (Anthropic) — optional. Ohne Key: rein regelbasiertes Melden ──────────
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MAX_TOKENS=1024

# ── Alert-Kanäle: mind. einer nötig (SMTP ODER Discord), außer DRY_RUN=true ────
# E-Mail (SMTP):
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=log-watcher@oberschmid.homes
SMTP_TO=p.oberschmid@cp-solutions.at
SMTP_TLS=true
# Discord (Webhook-URL; reicht auch allein, ohne SMTP):
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXX/YYYY

# ── State / Dedupe ────────────────────────────────────────────────────────────
STATE_FILE=/data/state.json
COOLDOWN_HOURS=12

# ── Health / Heartbeat (Docker-Healthcheck) ──────────────────────────────────
HEARTBEAT_FILE=/data/heartbeat
HEARTBEAT_INTERVAL_SECONDS=60
HEALTH_MAX_STALENESS_SECONDS=180

# ── Sonstiges ─────────────────────────────────────────────────────────────────
# DRY_RUN=true        # keine Mail senden, nur loggen (zum Einrichten/Testen)
# SELFTEST=true       # einmaliger Konfig-Check (Probe + Trockenlauf) und beenden
# NOTIFY_ON_START=true  # einmalige "gestartet"-Mail beim Start (Verkabelung testen)

# ── Identität / Baseline ──────────────────────────────────────────────────────
TARGET_NAME=default
# Vergleichsfenster: previous (Vorfenster) | yesterday (-24h) | last_week (-7d):
BASELINE_MODE=previous

# ── Warn-Spike (Feature 8 nutzt Fingerprinting automatisch) ───────────────────
# (siehe oben MIN_WARNINGS/WARN_SPIKE_FACTOR/ALERT_ON_WARN_SPIKE)

# ── LLM-Budget / Cache / Samples / Scrubbing ──────────────────────────────────
LLM_MAX_CALLS_PER_DAY=50      # danach regelbasiert (11)
LLM_VERDICT_TTL_HOURS=12      # gleiche Signatur nicht erneut bewerten (12)
LLM_INCLUDE_SAMPLES=true      # einige redigierte Beispiel-Logzeilen an den LLM (14)
LLM_SAMPLE_SIZE=5
LLM_SAMPLE_FIELD=message
SCRUB_PII=true                # E-Mails/IPs/Tokens vor LLM/Mail/ES entfernen (19)

# ── HTTP-Server (Features 15/16) ──────────────────────────────────────────────
HTTP_PORT=0                   # >0 aktiviert /healthz /status /metrics

# ── Replay (Feature 18): Regeln über einen vergangenen Zeitraum testen, dann Ende
# REPLAY_FROM=2026-05-01T00:00:00
# REPLAY_TO=2026-05-08T00:00:00

# ── Digest (Feature 4): periodische Zusammenfassung ───────────────────────────
DIGEST_ENABLED=false
DIGEST_HOUR_UTC=7
DIGEST_PERIOD_DAYS=1          # 1=täglich, 7=wöchentlich

# ── Multi-Target (Feature 17): mehrere Index-Gruppen mit eigenen Schwellen ─────
# Wenn gesetzt, überstimmt CONFIG_FILE die meisten ENV-Werte (siehe config.example.yaml):
# CONFIG_FILE=/data/config.yaml

# ── Netz ──────────────────────────────────────────────────────────────────────
# log-watcher ist ein eigenständiger Stack (eigenes Bridge-Netz, keine fremden Netze).
# ES wird über den Host erreicht (compose.yaml: extra_hosts host.docker.internal=host-gateway).
